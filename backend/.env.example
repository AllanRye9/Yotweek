# Postgres connection string
DATABASE_URL="postgresql://user:password@localhost:5432/yotweek?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
FRONTEND_URL="http://localhost:3000"

# Payments (mobile money / card aggregator - e.g. Flutterwave, Pesapal, DPO)
PAYMENT_PROVIDER_API_KEY=""
PAYMENT_PROVIDER_SECRET=""
PLATFORM_COMMISSION_PCT=5

# Weather (Open-Meteo requires no API key; kept here in case you swap providers)
WEATHER_PROVIDER="open-meteo"

# Email (SMTP - works with any provider: Gmail App Passwords, SendGrid,
# Mailgun, Resend's SMTP relay, Amazon SES, your own mail server, etc.)
# Leave SMTP_HOST unset in development and emails will just be logged
# instead of sent - useful for local testing without a real mailbox.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="yotweek <no-reply@yotweek.com>"
