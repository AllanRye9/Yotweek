# ─── Database ─────────────────────────────────────────────────────────────────
# Railway: copy the Internal Database URL from your Postgres service variables.
# Local:   postgresql://postgres:postgres@localhost:5432/yotweek
DATABASE_URL="postgresql://user:password@localhost:5432/yotweek?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed frontend origins. On Railway, set this to
# your frontend service's public URL, e.g. https://yotweek-frontend.up.railway.app
FRONTEND_URL="http://localhost:3000"

# ─── Image uploads ────────────────────────────────────────────────────────────
# Where uploaded listing/highlight photos are written on disk. Defaults to
# ./uploads if unset — fine locally, but on Railway (or any host with an
# ephemeral filesystem) point this at a mounted persistent Volume, e.g.
# /app/uploads, or uploads will be lost on every redeploy. See README
# "Images on listings" for the full explanation and an S3/R2 alternative.
UPLOAD_DIR=""
# Only needed if you put a CDN/reverse proxy in front of this API — otherwise
# upload URLs are built from the incoming request's own host automatically.
PUBLIC_UPLOAD_BASE_URL=""

# ─── Payments ─────────────────────────────────────────────────────────────────
# Wire in Flutterwave, Pesapal, or DPO credentials here.
PAYMENT_PROVIDER_API_KEY=""
PAYMENT_PROVIDER_SECRET=""
PLATFORM_COMMISSION_PCT=5

# ─── Email (optional) ─────────────────────────────────────────────────────────
# Leave SMTP_HOST blank in development — emails are logged to console instead.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="yotweek <no-reply@yotweek.com>"
