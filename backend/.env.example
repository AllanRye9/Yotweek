# ─── Database ─────────────────────────────────────────────────────────────────
# Railway: copy the Internal Database URL from your Postgres service variables.
# Local:   postgresql://postgres:postgres@localhost:5432/yotweek
DATABASE_URL="postgresql://user:password@yotweek:5432/yotweek?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="valuena"
JWT_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed frontend origins. On Railway, set this to
# your frontend service's public URL, e.g. https://yotweek-frontend.up.railway.app
FRONTEND_URL="http://localhost:3000"

# ─── Payments ─────────────────────────────────────────────────────────────────
# Wire in Flutterwave, Pesapal, or DPO credentials here.
PAYMENT_PROVIDER_API_KEY=""
PAYMENT_PROVIDER_SECRET=""
PLATFORM_COMMISSION_PCT=5

# ─── Email (optional) ─────────────────────────────────────────────────────────
# Leave SMTP_HOST blank in development — emails are logged to console instead.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="yotweek <no-reply@yotweek.com>"
