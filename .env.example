# ── Docker Compose / self-hosted ──────────────────────────────────────────────
# Copy to .env, fill in real values, then: docker compose up -d --build

POSTGRES_USER=yotweek
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=yotweek

JWT_SECRET=change-me-run-node-e-consolelog-requirecrypto-randomBytes48-toString-hex

# Public-facing URL of the FRONTEND (used for backend CORS allow-list)
# Comma-separate multiple: "http://localhost:3000,https://yourdomain.com"
FRONTEND_URL=http://localhost:3000

# Public-facing URL the BROWSER uses to reach the BACKEND API
# (baked into the Next.js bundle at build time — changing it requires a rebuild)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
