# Used by docker-compose.yml. Copy to .env and fill in real values before
# running `docker compose up -d --build`.

POSTGRES_USER=yotweek
POSTGRES_PASSWORD=change-me
POSTGRES_DB=yotweek

JWT_SECRET=change-me-to-a-long-random-string

# Public URL of the frontend (used for CORS on the backend)
FRONTEND_URL=https://yourdomain.com

# Public URL the browser will call for the API (baked into the frontend build)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
